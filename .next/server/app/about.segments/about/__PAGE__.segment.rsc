0:{"buildId":"8D9hsxrSg4PFgxUJdfgaa","rsc":["$","$1","c",{"children":[["$","$L2",null,{"initialData":{"data":{"id":4,"documentId":"xnqtaxv4vtnn6dck61u3kd15","hero_breadcrumb":"AgAsset Corporate Presentation","hero_title":"OUR COMPANY","hero_subtitle":"Execution Platform for Productive Assets","hero_description":"AgAssetCo is a Special Purpose Vehicle (SPV) designed to: \n\n•  Finance productive equipment portfolios\n• Aggregate distributed demand\n• Structure vendor-backed financing\n• De-risk energy project utilization\n• Provide long-term asset management","structure_title":"Structure","structure_section_title":"Built for Institutional Scale","structure_description":"Energy developers build power systems. SMEs operate businesses. AgAssetCo finances and manages the productive assets between them.","operations_title":"Beyond Financing — Full Asset Governance","operations_description":"Financing without management leads to asset decay. We integrate financing with structured oversight.","values_section_title":null,"mission_title":"Converting Electrons into Enterprise","mission_description":"To institutionalize Productive Use of Energy through structured asset financing and disciplined portfolio management.","vision_title":"Our Vision","vision_description":"A distributed energy ecosystem where every installed kilowatt is matched with productive industrial load.","model_title":"Vendor Financing & Asset-as-a-Service","model_description":"We replace heavy upfront capital expenditure with structured financing mechanisms:","governance_title":"Guided by Industry Veterans.","cta_heading":"Align Your Capital with Impact.","cta_description":"By choosing renewable energy financing, you lower energy costs, reduce carbon emissions, and support innovative solutions that benefit our planet. Whether you are a mini-grid developer seeking utilization or an investor seeking impact, we have the vehicle to execute.","corporate_profile_label":"Corporate Profile","impact_report_label":"Impact Report","partnerships_link_text":"Explore Partnerships","createdAt":"2026-02-19T18:16:15.027Z","updatedAt":"2026-03-31T22:15:54.861Z","publishedAt":"2026-03-31T22:15:55.651Z"},"meta":{}}}],[["$","script","script-0",{"src":"/_next/static/chunks/1da5a28e0f5dbc8a.js","async":true}]],["$","$L3",null,{"children":["$","$4",null,{"name":"Next.MetadataOutlet","children":"$@5"}]}]]}],"loading":null,"isPartial":false}
