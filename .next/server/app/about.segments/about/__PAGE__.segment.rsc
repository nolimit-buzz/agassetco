0:{"buildId":"ZmfRhSTnblstY4aSimUtL","rsc":["$","$1","c",{"children":[["$","$L2",null,{"initialData":{"data":{"id":2,"documentId":"xnqtaxv4vtnn6dck61u3kd15","hero_breadcrumb":"AgAsset Corporate Presentation","hero_title":"EXECUTION ENGINE.","hero_subtitle":"ENGINE","hero_description":"AgAsset Co is a specialized asset vehicle dedicated to bridging the gap between energy access and productive use. We finance, deploy, and manage machinery at scale.","structure_title":"Purpose-Built for Scale.","structure_section_title":"The Last Mile Solution","structure_description":"While developers build grids and farmers grow crops, a missing link remained: the capital-intensive machinery required to process harvest. We fill that void.","operations_title":"Operational Excellence Beyond the Grid.","operations_description":"Financing is easy. Keeping assets running in remote locations is hard. That is our core competency. We leverage real-time data to de-risk investments and maximize runtime.","values_section_title":"The Values That Drive Us.","mission_title":"The Impact Mandate","mission_description":"To de-risk the adoption of productive machinery in rural markets, turning energy access into tangible economic output.","vision_title":"Community Wealth","vision_description":"A continent where every electron generated by a mini-grid is consumed by a machine that creates wealth for a community.","model_title":"Asset-as-a-Service","model_description":"We believe ownership shouldn't be a barrier. Our model replaces high CapEx with manageable OpEx, aligned with harvest cycles.","governance_title":"Guided by Industry Veterans.","cta_heading":"Align Your Capital with Impact.","cta_description":"By choosing renewable energy financing, you lower energy costs, reduce carbon emissions, and support innovative solutions that benefit our planet. Whether you are a mini-grid developer seeking utilization or an investor seeking impact, we have the vehicle to execute.","corporate_profile_label":"Corporate Profile","impact_report_label":"Impact Report","partnerships_link_text":"Explore Partnerships","createdAt":"2026-02-19T09:16:15.027Z","updatedAt":"2026-02-20T09:21:45.408Z","publishedAt":"2026-02-20T09:21:52.654Z"},"meta":{}}}],[["$","script","script-0",{"src":"/_next/static/chunks/1da5a28e0f5dbc8a.js","async":true}]],["$","$L3",null,{"children":["$","$4",null,{"name":"Next.MetadataOutlet","children":"$@5"}]}]]}],"loading":null,"isPartial":false}
