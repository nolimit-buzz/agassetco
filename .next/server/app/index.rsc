8:[["$","$L11",null,{"data":{"__component":"sections.hero","id":3,"eyebrow":"Productive Asset Financing for Distributed Energy Markets","title":[{"type":"paragraph","children":[{"text":"We finance, deploy, and manage productive equipment that converts electricity into economic output — strengthening demand, improving energy project bankability, and unlocking rural industrial growth.","type":"text"}]}],"subtitle":[{"type":"paragraph","children":[{"text":"We finance, deploy, and manage productive equipment that converts electricity into economic output — strengthening demand, improving energy project bankability, and unlocking rural industrial growth.","type":"text"}]}],"primaryButtonLabel":"Partner With Us","primaryButtonUrl":"/contact","secondaryButtonLabel":"Explore Our Portfolio","secondaryButtonUrl":"/portfolio","badgeText":"AGRICULTURE • MINI-GRIDS • IMPACT"}}],["$","$L12",null,{"data":{"__component":"sections.trust-bar","id":3,"label":"Trusted by Global Institutions & Infrastructure Leaders"}}],["$","$L13",null,{"data":{"__component":"sections.introduction","id":4,"sectionLabel":"01 : Introduction","title":[{"type":"paragraph","children":[{"text":"The Missing Link Between Energy and Industry","type":"text"}]}],"body":[{"type":"paragraph","children":[{"text":"AgAssetCo is a specialized asset financing and management platform focused on the Productive Use of Energy (PUE).","type":"text"}]},{"type":"paragraph","children":[{"text":"We do not generate electricity. We do not build grids.","type":"text"}]},{"type":"paragraph","children":[{"text":"We finance and manage the machinery that consumes power productively — agro-processing equipment, cold chain systems, water systems, mobility assets, and light industrial equipment.","type":"text"}]}]}}],["$","$L14",null,{"data":{"__component":"sections.introduction","id":5,"sectionLabel":"02 : The Challenge","title":[{"type":"paragraph","children":[{"text":"The Structural Gap in Energy Markets","type":"text"}]}],"body":[{"ty