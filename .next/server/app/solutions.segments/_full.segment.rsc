8:["$","$L11",null,{"initialData":{"data":{"id":4,"documentId":"jthyvr6n0bu2w2zpjh5pp5gm","hero_breadcrumb":"Productive Use of Energy Platform","hero_title":"PUE-AS-A-SERVICE.","hero_subtitle":"SERVICE","hero_description":"We finance and manage portfolios across:","management_title":null,"management_heading":null,"b2b_heading":null,"b2b_description":null,"cta_heading":null,"cta_description":null,"createdAt":"2026-02-20T17:12:20.049Z","updatedAt":"2026-03-31T22:17:16.768Z","publishedAt":"2026-03-31T22:17:18.160Z","models":[{"id":3,"label":"Model A ","title":" Vendor Financing Model","description":"AgAssetCo finances equipment deployment. Ownership transfers upon full repayment. Structured cashflow-based repayment model."},{"id":4,"label":"Model B ","title":"PUE-as-a-Service","description":"AgAssetCo retains ownership. Users pay per service (kg/hour/liter/km). Full O&M included."}],"asset_categories":[{"id":11,"title":"Agro-Processing","description":null},{"id":12,"title":"Cold Chain","description":null},{"id":13,"title":"Water & irrigation","description":null},{"id":14,"title":"Light manufacturing","description":null},{"id":15,"title":"E-mobility","description":null},{"id":16,"title":"Commercial productive loads","description":null}],"management_features":[{"id":7,"title":"Hub-and-Spoke Oversight Model","description":"• Smart Asset Selection (Commercial viability screening)\n• IoT Telemetry & Energy Analytics\n• Remote Performance Control\n• Local Technical Support Network"},{"id":8,"title":"Partnering With Energy Developers","description":"Your infrastructure needs productive demand. We structure, finance, and manage the load.\nBenefits:\n• Increased daytime utilization\n• Anchor load stability\n• Improved ARPU\n• Stronger project bankability\n• Structured demand aggregation\n• Integrated smart metering alignment\n"}],"b2b_checklist":[{"id":9,"text":"Daytime consumption optimization"}],"faqs":[{"id":7,"question":"How do you handle credit risk in remote areas?","answer":"We utilize a three-layered approach: rigorous upfront vetting via Agronomie's agricultural data, mandatory digital payment collection, and IoT-enabled remote lockout capabilities for non-compliant assets."},{"id":8,"question":"Are the machines AC or DC powered?","answer":"Our portfolio is grid-agnostic. We provide equipment tailored to the specific electrical architecture of the site, whether it's a 230V AC mini-grid or specialized 48V/96V DC solar systems."},{"id":9,"question":"What happens when a machine breaks down?","answer":"We maintain a hub-and-spoke O&M model. Our central operations center tracks performance telemetry, while localized rapid response teams handle physical repairs and spare parts inventory."}]},"meta":{}}}]
